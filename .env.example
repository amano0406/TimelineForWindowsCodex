# Copy to `.env` and adjust for the machine that runs Docker Compose.
#
# WSL example:
# HOST_TIMELINE_DATA=/mnt/c/TimelineData
# HOST_CODEX_HOME=/mnt/c/Users/amano/.codex
# HOST_CODEX_BACKUP_HOME=/mnt/c/Codex/archive/migration-backup-2026-03-27/codex-home
# HOST_CODEX_ROOT=/mnt/c/Codex
#
# PowerShell / cmd example:
# HOST_TIMELINE_DATA=C:\TimelineData
# HOST_CODEX_HOME=C:\Users\amano\.codex
# HOST_CODEX_BACKUP_HOME=C:\Codex\archive\migration-backup-2026-03-27\codex-home
# HOST_CODEX_ROOT=C:\Codex

HOST_TIMELINE_DATA=/mnt/c/TimelineData
HOST_CODEX_HOME=/mnt/c/Users/amano/.codex
HOST_CODEX_BACKUP_HOME=/mnt/c/Codex/archive/migration-backup-2026-03-27/codex-home
HOST_CODEX_ROOT=/mnt/c/Codex
