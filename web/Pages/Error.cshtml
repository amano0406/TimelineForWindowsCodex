@page
@model WindowsCodex2Timeline.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="app-page space-y-6">
    <header class="panel page-header">
        <div>
            <p class="eyebrow">windowscodex2timeline</p>
            <h1 class="page-title">Application error</h1>
            <p class="page-description">The request could not be completed.</p>
        </div>
    </header>

    <section class="panel error-panel">
        <p class="font-medium text-slate-900">An unexpected error occurred while rendering this page.</p>
        @if (Model.ShowRequestId)
        {
            <p class="mt-3 text-sm text-slate-600">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }
    </section>
</section>
