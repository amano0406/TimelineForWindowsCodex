@page "/jobs/new"
@model TimelineForWindowsCodex.Web.Pages.Jobs.NewModel
@inject TimelineForWindowsCodex.Web.Services.LanguageService LanguageService
@inject TimelineForWindowsCodex.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    ViewData["Title"] = L("jobs.new.page_title");
}

<section class="app-page space-y-6">
    <header class="panel page-header">
        <div>
            <p class="eyebrow">@L("jobs.new.eyebrow")</p>
            <h1 class="page-title">@L("jobs.new.page_title")</h1>
            <p class="page-description">@L("jobs.new.description")</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <form method="post" asp-route-lang="@lang" class="space-y-6">
        @if (!ViewContext.ModelState.IsValid)
        {
            <section class="panel error-panel">
                <ul class="list-disc space-y-1 pl-5">
                    @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </section>
        }

        <div class="grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
            <section class="panel space-y-4">
                <div>
                    <h2 class="section-title">@L("jobs.new.source_title")</h2>
                    <p class="text-sm text-slate-600">@L("jobs.new.source_description")</p>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900" asp-for="PrimaryCodexHomePath">@L("jobs.new.primary_root")</label>
                    <input asp-for="PrimaryCodexHomePath" class="app-input" />
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900" asp-for="BackupCodexHomePathsText">@L("jobs.new.backup_roots")</label>
                    <textarea asp-for="BackupCodexHomePathsText" class="app-textarea" rows="4"></textarea>
                    <p class="text-xs text-slate-500">@L("jobs.new.roots_hint")</p>
                </div>

                <div class="grid gap-4 md:grid-cols-2">
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-900" asp-for="DateFrom">@L("jobs.new.date_from")</label>
                        <input asp-for="DateFrom" type="date" class="app-input" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-900" asp-for="DateTo">@L("jobs.new.date_to")</label>
                        <input asp-for="DateTo" type="date" class="app-input" />
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-medium text-slate-900" asp-for="RedactionProfile">@L("jobs.new.redaction")</label>
                    <select asp-for="RedactionProfile" class="app-select">
                        <option value="strict">@L("jobs.new.redaction_strict")</option>
                        <option value="loose">@L("jobs.new.redaction_loose")</option>
                    </select>
                </div>

                <label class="checkbox-row">
                    <input asp-for="IncludeArchivedSources" type="checkbox" />
                    <span>@L("jobs.new.include_archived")</span>
                </label>

                <label class="checkbox-row">
                    <input asp-for="IncludeToolOutputs" type="checkbox" />
                    <span>@L("jobs.new.include_tool_outputs")</span>
                </label>

                <div class="flex flex-wrap gap-3">
                    <button asp-page-handler="Refresh" asp-route-lang="@lang" class="btn-secondary">@L("jobs.new.refresh")</button>
                    <button asp-page-handler="Execute" asp-route-lang="@lang" class="btn-primary">@L("jobs.new.execute")</button>
                </div>
            </section>

            <section class="panel space-y-4">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h2 class="section-title">@L("jobs.new.thread_title")</h2>
                        <p class="text-sm text-slate-600">@L("jobs.new.thread_description")</p>
                    </div>
                    <div class="badge-chip">@Model.DiscoveredThreads.Count</div>
                </div>

                @if (Model.DiscoveredThreads.Count == 0)
                {
                    <div class="selection-empty">@L("jobs.new.no_threads")</div>
                }
                else
                {
                    <p class="text-sm text-slate-600">@string.Format(System.Globalization.CultureInfo.CurrentCulture, L("jobs.new.discovered_count"), Model.DiscoveredThreads.Count)</p>
                    <div class="selection-list-shell">
                        <ul class="space-y-3">
                            @foreach (var thread in Model.DiscoveredThreads)
                            {
                                var isChecked = Model.SelectedThreadIds.Any(id => string.Equals(id, thread.ThreadId, StringComparison.OrdinalIgnoreCase));
                                <li class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                                    <label class="flex gap-4">
                                        <input type="checkbox" name="SelectedThreadIds" value="@thread.ThreadId" checked="@isChecked" class="mt-1" />
                                        <div class="min-w-0 flex-1">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <div class="font-medium text-slate-950">@thread.PreferredTitle</div>
                                                <span class="status-badge status-badge-neutral">@thread.SourceRootKind</span>
                                            </div>
                                            <div class="mt-2 text-xs text-slate-500">@thread.ThreadId</div>
                                            @if (!string.IsNullOrWhiteSpace(thread.UpdatedAt))
                                            {
                                                <div class="mt-1 text-sm text-slate-600">@thread.UpdatedAt</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(thread.Cwd))
                                            {
                                                <div class="mt-2 text-sm text-slate-600">@thread.Cwd</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(thread.FirstUserMessageExcerpt))
                                            {
                                                <div class="mt-3 rounded-xl bg-slate-50 px-3 py-2 text-sm text-slate-700">
                                                    @thread.FirstUserMessageExcerpt
                                                </div>
                                            }
                                        </div>
                                    </label>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </section>
        </div>
    </form>
</section>
