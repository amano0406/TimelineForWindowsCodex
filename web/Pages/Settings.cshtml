@page "/settings"
@model WindowsCodex2Timeline.Web.Pages.SettingsModel
@using Microsoft.AspNetCore.WebUtilities
@inject WindowsCodex2Timeline.Web.Services.LanguageService LanguageService
@inject WindowsCodex2Timeline.Web.Services.JsonLocalizationService Localizer
@{
    var lang = LanguageService.Resolve(ViewContext.HttpContext.Request);
    string L(string key) => Localizer.Get(lang, key);
    string LinkWithLang(string href) => QueryHelpers.AddQueryString(href, "lang", lang);
    ViewData["Title"] = L("settings.page_title");
}

<section class="app-page space-y-6">
    <header class="panel page-header">
        <div>
            <p class="eyebrow">@L("settings.eyebrow")</p>
            <h1 class="page-title">@L("settings.page_title")</h1>
            <p class="page-description">@L("settings.description")</p>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <section class="panel notice-panel">
            @Model.StatusMessage
        </section>
    }

    <form method="post" asp-route-lang="@lang" class="space-y-6">
        @if (!ViewContext.ModelState.IsValid)
        {
            <section class="panel error-panel">
                <ul class="list-disc space-y-1 pl-5">
                    @foreach (var error in ViewContext.ModelState.Values.SelectMany(static value => value.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </section>
        }

        <section class="panel space-y-4">
            <div>
                <h2 class="section-title">@L("settings.defaults_title")</h2>
                <p class="text-sm text-slate-600">@L("settings.defaults_description")</p>
            </div>

            <div class="space-y-2">
                <label asp-for="DefaultPrimaryCodexHomePath" class="text-sm font-medium text-slate-900">@L("jobs.new.primary_root")</label>
                <input asp-for="DefaultPrimaryCodexHomePath" class="app-input" />
            </div>

            <div class="space-y-2">
                <label asp-for="DefaultBackupCodexHomePathsText" class="text-sm font-medium text-slate-900">@L("jobs.new.backup_roots")</label>
                <textarea asp-for="DefaultBackupCodexHomePathsText" class="app-textarea" rows="4"></textarea>
            </div>

            <div class="space-y-2">
                <label asp-for="DefaultEnrichmentRootPathsText" class="text-sm font-medium text-slate-900">@L("settings.enrichment_roots")</label>
                <textarea asp-for="DefaultEnrichmentRootPathsText" class="app-textarea" rows="4"></textarea>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
                <div class="space-y-2">
                    <label asp-for="DefaultRedactionProfile" class="text-sm font-medium text-slate-900">@L("jobs.new.redaction")</label>
                    <select asp-for="DefaultRedactionProfile" class="app-select">
                        <option value="strict">@L("jobs.new.redaction_strict")</option>
                        <option value="loose">@L("jobs.new.redaction_loose")</option>
                    </select>
                </div>

                <div class="space-y-2">
                    <label asp-for="UiLanguage" class="text-sm font-medium text-slate-900">@L("settings.ui_language")</label>
                    <select asp-for="UiLanguage" class="app-select">
                        @foreach (var language in Model.SupportedLanguages)
                        {
                            <option value="@language.Code">@language.NativeName</option>
                        }
                    </select>
                </div>
            </div>

            <label class="checkbox-row">
                <input asp-for="DefaultIncludeArchivedSources" type="checkbox" />
                <span>@L("jobs.new.include_archived")</span>
            </label>

            <label class="checkbox-row">
                <input asp-for="DefaultIncludeToolOutputs" type="checkbox" />
                <span>@L("jobs.new.include_tool_outputs")</span>
            </label>

            <div class="flex flex-wrap gap-3">
                <button type="submit" class="btn-primary">@L("common.save")</button>
                <a class="btn-secondary" href="@LinkWithLang("/jobs/new")">@L("common.cancel")</a>
            </div>
        </section>
    </form>
</section>
