@using Microsoft.AspNetCore.WebUtilities
@inject WindowsCodex2Timeline.Web.Services.LanguageService LanguageService
@inject WindowsCodex2Timeline.Web.Services.JsonLocalizationService Localizer
@inject WindowsCodex2Timeline.Web.Services.AppPaths AppPaths
@{
    var lang = LanguageService.Resolve(Context.Request);
    var currentPath = Context.Request.Path.Value ?? "/";
    var supportedLanguages = LanguageService.GetSupportedLanguages();
    string L(string key) => Localizer.Get(lang, key);
    string LinkWithLang(string href, string? targetLang = null) => QueryHelpers.AddQueryString(href, "lang", targetLang ?? lang);
    string CurrentPathWithLang(string targetLang) => QueryHelpers.AddQueryString(currentPath, "lang", targetLang);

    string NavClass(string href)
    {
        var isJobsSection = string.Equals(href, "/jobs", StringComparison.OrdinalIgnoreCase) &&
            (string.Equals(currentPath, "/jobs", StringComparison.OrdinalIgnoreCase) ||
             (currentPath.StartsWith("/jobs/", StringComparison.OrdinalIgnoreCase) &&
              !currentPath.StartsWith("/jobs/new", StringComparison.OrdinalIgnoreCase)));

        var isActive =
            isJobsSection ||
            string.Equals(currentPath, href, StringComparison.OrdinalIgnoreCase) ||
            (!string.Equals(href, "/jobs", StringComparison.OrdinalIgnoreCase) &&
             currentPath.StartsWith($"{href}/", StringComparison.OrdinalIgnoreCase));

        return isActive ? "nav-link nav-link-active" : "nav-link";
    }
}
<!DOCTYPE html>
<html lang="@lang" data-app-theme="workbench">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - windowscodex2timeline</title>
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/web.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="space-y-6">
                <div class="space-y-3">
                    <a href="@LinkWithLang("/jobs/new")" class="brand-link">
                        <div class="space-y-1">
                            <div class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">@L("layout.brand_eyebrow")</div>
                            <div class="text-xl font-semibold text-slate-950">windowscodex2timeline</div>
                            <div class="text-sm text-slate-500">@L("layout.brand_description")</div>
                        </div>
                    </a>
                </div>

                <nav class="space-y-2">
                    <a href="@LinkWithLang("/jobs/new")" class="@NavClass("/jobs/new")">@L("layout.new_job")</a>
                    <a href="@LinkWithLang("/jobs")" class="@NavClass("/jobs")">@L("layout.jobs")</a>
                    <a href="@LinkWithLang("/settings")" class="@NavClass("/settings")">@L("layout.settings")</a>
                </nav>

                <div class="space-y-2">
                    <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">@L("layout.language")</div>
                    <div class="language-switch">
                        @foreach (var language in supportedLanguages)
                        {
                            var isActive = string.Equals(lang, language.Code, StringComparison.OrdinalIgnoreCase);
                            <a href="@CurrentPathWithLang(language.Code)"
                               class="@(isActive ? "language-pill language-pill-active" : "language-pill")">@language.Code.ToUpperInvariant()</a>
                        }
                    </div>
                </div>
            </div>
        </aside>

        <div class="app-content">
            <main class="app-main">
                @RenderBody()
            </main>
        </div>
    </div>
    <div id="app-update-banner"
         class="fixed bottom-4 right-4 hidden rounded-xl border border-slate-200 bg-slate-950 px-4 py-3 text-sm font-medium text-white shadow-2xl">
        @L("layout.update_detected")
    </div>
    <script>
        (() => {
            const currentInstanceId = "@AppPaths.InstanceId";
            const pollIntervalMs = 10000;
            const banner = document.getElementById("app-update-banner");
            let checking = false;

            const triggerReload = () => {
                banner?.classList.remove("hidden");
                location.reload();
            };

            const checkVersion = async () => {
                if (checking) {
                    return;
                }

                checking = true;
                try {
                    const response = await fetch("/api/app/version", {
                        method: "GET",
                        cache: "no-store",
                        headers: { "Accept": "application/json" }
                    });
                    if (!response.ok) {
                        return;
                    }

                    const payload = await response.json();
                    if (payload?.instance_id && payload.instance_id !== currentInstanceId) {
                        triggerReload();
                    }
                } catch {
                } finally {
                    checking = false;
                }
            };

            setInterval(checkVersion, pollIntervalMs);
            document.addEventListener("visibilitychange", () => {
                if (!document.hidden) {
                    checkVersion();
                }
            });
            window.addEventListener("focus", checkVersion);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
